<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hand Gesture Controller</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #1a1a2e;
            color: #eee;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }
        h1 { margin-bottom: 20px; color: #e94560; }

        .container {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .video-box {
            position: relative;
            border: 2px solid #e94560;
            border-radius: 12px;
            overflow: hidden;
        }
        video, canvas {
            display: block;
            width: 640px;
            height: 480px;
            border-radius: 10px;
        }
        #overlay {
            position: absolute;
            top: 0;
            left: 0;
            pointer-events: none;
        }

        .info-panel {
            background: #16213e;
            border-radius: 12px;
            padding: 20px;
            min-width: 260px;
            max-width: 300px;
        }
        .info-panel h2 {
            color: #e94560;
            margin-bottom: 10px;
            margin-top: 15px;
            font-size: 16px;
        }
        .info-panel h2:first-child { margin-top: 0; }

        .gesture-display {
            font-size: 48px;
            text-align: center;
            padding: 15px;
            margin-bottom: 10px;
            background: #0f3460;
            border-radius: 8px;
        }
        .gesture-label {
            text-align: center;
            font-size: 16px;
            font-weight: bold;
            margin-bottom: 15px;
            color: #e94560;
        }

        .finger-bar {
            display: flex;
            align-items: center;
            margin-bottom: 6px;
            gap: 8px;
        }
        .finger-bar .name {
            width: 55px;
            font-size: 12px;
        }
        .finger-bar .bar {
            flex: 1;
            height: 14px;
            background: #0f3460;
            border-radius: 7px;
            overflow: hidden;
        }
        .finger-bar .bar-fill {
            height: 100%;
            border-radius: 7px;
            transition: width 0.1s;
        }
        .finger-bar .angle {
            width: 40px;
            text-align: right;
            font-size: 11px;
            color: #999;
        }

        .divider {
            border: none;
            border-top: 1px solid #0f3460;
            margin: 12px 0;
        }

        .status {
            margin-top: 12px;
            padding: 8px;
            border-radius: 8px;
            text-align: center;
            font-size: 13px;
        }
        .status.connected { background: #1b4332; color: #95d5b2; }
        .status.disconnected { background: #4a1a1a; color: #f5a5a5; }

        .controls {
            margin-top: 10px;
            display: flex;
            gap: 10px;
        }
        .controls button {
            flex: 1;
            padding: 8px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 13px;
            background: #e94560;
            color: white;
        }
        .controls button:hover { background: #c23152; }
        .controls button.active { background: #2ecc71; }

        .fps { color: #666; font-size: 12px; margin-top: 8px; text-align: center; }
    </style>
</head>
<body>

<h1>Hand Gesture Controller</h1>

<div class="container">
    <!-- Video -->
    <div class="video-box">
        <video id="webcam" autoplay playsinline></video>
        <canvas id="overlay"></canvas>
    </div>

    <!-- Info Panel -->
    <div class="info-panel">
        <h2>Gesture</h2>
        <div class="gesture-display" id="gestureEmoji">🖐️</div>
        <div class="gesture-label" id="gestureLabel">Waiting...</div>

        <h2>Hand 1</h2>
        <div class="finger-bar">
            <span class="name">Thumb</span>
            <div class="bar"><div class="bar-fill" id="bar-thumb-L" style="width:0%;background:#e74c3c"></div></div>
            <span class="angle" id="angle-thumb-L">-</span>
        </div>
        <div class="finger-bar">
            <span class="name">Index</span>
            <div class="bar"><div class="bar-fill" id="bar-index-L" style="width:0%;background:#e67e22"></div></div>
            <span class="angle" id="angle-index-L">-</span>
        </div>
        <div class="finger-bar">
            <span class="name">Middle</span>
            <div class="bar"><div class="bar-fill" id="bar-middle-L" style="width:0%;background:#f1c40f"></div></div>
            <span class="angle" id="angle-middle-L">-</span>
        </div>
        <div class="finger-bar">
            <span class="name">Ring</span>
            <div class="bar"><div class="bar-fill" id="bar-ring-L" style="width:0%;background:#2ecc71"></div></div>
            <span class="angle" id="angle-ring-L">-</span>
        </div>
        <div class="finger-bar">
            <span class="name">Pinky</span>
            <div class="bar"><div class="bar-fill" id="bar-pinky-L" style="width:0%;background:#3498db"></div></div>
            <span class="angle" id="angle-pinky-L">-</span>
        </div>

        <hr class="divider">

        <h2>Hand 2</h2>
        <div class="finger-bar">
            <span class="name">Thumb</span>
            <div class="bar"><div class="bar-fill" id="bar-thumb-R" style="width:0%;background:#e74c3c"></div></div>
            <span class="angle" id="angle-thumb-R">-</span>
        </div>
        <div class="finger-bar">
            <span class="name">Index</span>
            <div class="bar"><div class="bar-fill" id="bar-index-R" style="width:0%;background:#e67e22"></div></div>
            <span class="angle" id="angle-index-R">-</span>
        </div>
        <div class="finger-bar">
            <span class="name">Middle</span>
            <div class="bar"><div class="bar-fill" id="bar-middle-R" style="width:0%;background:#f1c40f"></div></div>
            <span class="angle" id="angle-middle-R">-</span>
        </div>
        <div class="finger-bar">
            <span class="name">Ring</span>
            <div class="bar"><div class="bar-fill" id="bar-ring-R" style="width:0%;background:#2ecc71"></div></div>
            <span class="angle" id="angle-ring-R">-</span>
        </div>
        <div class="finger-bar">
            <span class="name">Pinky</span>
            <div class="bar"><div class="bar-fill" id="bar-pinky-R" style="width:0%;background:#3498db"></div></div>
            <span class="angle" id="angle-pinky-R">-</span>
        </div>

        <div class="status connected" id="status">Connecting...</div>

        <div class="controls">
            <button id="btnToggle" onclick="toggleCapture()">Stop</button>
        </div>

        <div class="fps" id="fpsDisplay">FPS: -</div>
    </div>
</div>

<script>
    const video = document.getElementById('webcam');
    const overlay = document.getElementById('overlay');
    const ctx = overlay.getContext('2d');

    let capturing = true;
    let lastTime = performance.now();
    let frameCount = 0;

    const gestureMap = {
        'open':      { emoji: '🖐️', label: 'Open' },
        'fist':      { emoji: '✊',  label: 'Fist' },
        'point':     { emoji: '👆', label: 'Point' },
        'thumbs_up': { emoji: '👍', label: 'Thumbs Up' },
        'unknown':   { emoji: '❓', label: 'Unknown' },
    };

    async function startCamera() {
        try {
            const stream = await navigator.mediaDevices.getUserMedia({
                video: { width: 640, height: 480 }
            });
            video.srcObject = stream;
            video.addEventListener('loadeddata', () => {
                overlay.width = video.videoWidth;
                overlay.height = video.videoHeight;
                processLoop();
            });
        } catch (err) {
            document.getElementById('status').className = 'status disconnected';
            document.getElementById('status').textContent = 'Cannot access camera: ' + err.message;
        }
    }

    async function processLoop() {
        if (!capturing) {
            requestAnimationFrame(processLoop);
            return;
        }

        const tmpCanvas = document.createElement('canvas');
        tmpCanvas.width = video.videoWidth;
        tmpCanvas.height = video.videoHeight;
        tmpCanvas.getContext('2d').drawImage(video, 0, 0);
        const dataURL = tmpCanvas.toDataURL('image/jpeg', 0.7);

        try {
            const resp = await fetch('/process', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ frame: dataURL })
            });
            const result = await resp.json();
            updateUI(result);
        } catch (err) {
            document.getElementById('status').className = 'status disconnected';
            document.getElementById('status').textContent = 'Connection failed';
        }

        frameCount++;
        const now = performance.now();
        if (now - lastTime >= 1000) {
            document.getElementById('fpsDisplay').textContent = `FPS: ${frameCount}`;
            frameCount = 0;
            lastTime = now;
        }

        requestAnimationFrame(processLoop);
    }

    function updateUI(result) {
        ctx.clearRect(0, 0, overlay.width, overlay.height);

        if (!result.hands_detected) {
            document.getElementById('gestureEmoji').textContent = '🔍';
            document.getElementById('gestureLabel').textContent = 'No hand detected';
            for (const side of ['L', 'R']) {
                for (const f of ['thumb','index','middle','ring','pinky']) {
                    const bar = document.getElementById(`bar-${f}-${side}`);
                    const label = document.getElementById(`angle-${f}-${side}`);
                    if (bar) bar.style.width = '0%';
                    if (label) label.textContent = '-';
                }
            }
            return;
        }

        // Draw skeletons
        const colors = ['#00ff88', '#ff8800'];
        result.hands.forEach((hand, i) => {
            if (hand.landmarks) drawLandmarks(hand.landmarks, colors[i] || colors[0]);
        });

        // Gesture display
        const emojis = result.hands.map(h => (gestureMap[h.gesture] || gestureMap['unknown']).emoji);
        document.getElementById('gestureEmoji').textContent = emojis.join('  ');

        const labels = result.hands.map(h => (gestureMap[h.gesture] || gestureMap['unknown']).label);
        document.getElementById('gestureLabel').textContent = labels.join(' | ');

        // Angle bars
        result.hands.forEach((hand, i) => {
            const side = i === 0 ? 'L' : 'R';
            for (const [finger, angle] of Object.entries(hand.angles)) {
                const pct = (angle / 180) * 100;
                const bar = document.getElementById(`bar-${finger}-${side}`);
                const label = document.getElementById(`angle-${finger}-${side}`);
                if (bar) bar.style.width = pct + '%';
                if (label) label.textContent = Math.round(angle) + '°';
            }
        });

        document.getElementById('status').className = 'status connected';
        document.getElementById('status').textContent = 'Detecting';
    }

    function drawLandmarks(landmarks, color) {
        const w = overlay.width;
        const h = overlay.height;

        const connections = [
            [0,1],[1,2],[2,3],[3,4],
            [0,5],[5,6],[6,7],[7,8],
            [5,9],[9,10],[10,11],[11,12],
            [9,13],[13,14],[14,15],[15,16],
            [13,17],[17,18],[18,19],[19,20],[0,17]
        ];

        ctx.strokeStyle = color;
        ctx.lineWidth = 2;
        for (const [i, j] of connections) {
            ctx.beginPath();
            ctx.moveTo(landmarks[i].x * w, landmarks[i].y * h);
            ctx.lineTo(landmarks[j].x * w, landmarks[j].y * h);
            ctx.stroke();
        }

        for (const lm of landmarks) {
            ctx.beginPath();
            ctx.arc(lm.x * w, lm.y * h, 4, 0, Math.PI * 2);
            ctx.fillStyle = '#e94560';
            ctx.fill();
        }
    }

    function toggleCapture() {
        capturing = !capturing;
        const btn = document.getElementById('btnToggle');
        btn.textContent = capturing ? 'Stop' : 'Continue';
        btn.className = capturing ? '' : 'active';
    }

    startCamera();
</script>

</body>
</html>